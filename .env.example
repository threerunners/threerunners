TURSO_DATABASE_URL=libsql://your-db-name.aws-eu-west-1.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# Generate with: openssl rand -hex 32
ADMIN_SECRET=your-random-secret-string

# Initial admin user (used once by the seed script)
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=your-strong-password
